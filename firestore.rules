rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profile: only the signed-in user can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Module progress: document contains userId; only that user can read/write
    match /moduleProgress/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
    // Quiz results: document contains uid; only that user can read/write
    match /quizResults/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    // Segment quiz scores: one doc per user per module per segment
    match /segmentQuizScores/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    // Study sessions: allow authenticated users
    match /studySessions/{sessionId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null;
    }
    // Study goals: only owner can CRUD
    match /goals/{goalId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    // Study profiles: owner writes, all authenticated users can read (for matching)
    match /studyProfiles/{profileId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    // Adaptive difficulty: only owner can CRUD
    match /adaptiveDifficulty/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    // Community posts: any authenticated user can read/create, update for votes
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;

      // Replies subcollection
      match /replies/{replyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }
  }
}
