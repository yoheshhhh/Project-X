# ============================================
# NTUlearn Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# ---- Firebase ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Learner DNA demo (optional) ----
# Set to "true" to floor cognitive + readiness scores for demos (min 70 and 72)
# NEXT_PUBLIC_DEMO_MODE=true

# ---- Gemini (quiz + flashcards + "I'm lost" chatbot) ----
# Use GEMINI_API_KEY (server-only) or NEXT_PUBLIC_GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# ---- Azure OpenAI (optional; not used for quiz/flashcards) ----
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-06-01
